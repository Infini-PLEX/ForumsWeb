@page
@model ForumsWeb.Pages.Posts.DetailsModel
@{
    ViewData["Title"] = Model.Post?.Title;
}

<div style="margin-bottom: 1.5rem;">
    <a asp-page="/Posts/Index" asp-route-forumId="@Model.Post?.ForumId">&larr; Back to Posts</a>
</div>

@if (Model.Post != null)
{
    <div class="card" style="border-top: 4px solid var(--primary);">
        <h1 style="margin-top: 0; margin-bottom: 0.5rem;">@Model.Post.Title</h1>
        <small style="color: #64748b;">Original post on @Model.Post.CreatedAt.ToString("MMM dd, yyyy - HH:mm")</small>
        <hr style="margin: 1rem 0;" />
        <div style="white-space: pre-wrap; line-height: 1.6; font-size: 1.05rem;">@Model.Post.Content</div>
    </div>

    <h3 style="margin-top: 2rem; margin-bottom: 1rem; color: #334155;">Replies (@Model.Post.Replies.Count)</h3>

    <div style="display: flex; flex-direction: column; gap: 1rem; margin-bottom: 2rem;">
        @foreach(var reply in Model.Post.Replies.OrderBy(r => r.CreatedAt))
        {
            <div class="card" style="padding: 1rem 1.5rem; margin-bottom: 0; box-shadow: none;">
                <div style="margin-bottom: 0.5rem;">
                    <small style="color: #64748b; font-weight: 500;">Replied on @reply.CreatedAt.ToString("MMM dd, yyyy - HH:mm")</small>
                </div>
                <div style="white-space: pre-wrap; line-height: 1.5;">@reply.Content</div>
            </div>
        }
        
        @if(!Model.Post.Replies.Any())
        {
            <p style="color: #64748b; font-style: italic;">No replies yet. Start the conversation below!</p>
        }
    </div>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="card" style="background: #f8fafc;">
            <h4 style="margin-top: 0;">Add a Reply</h4>
            <form method="post">
                <input type="hidden" asp-for="Reply.PostId" value="@Model.Post.Id" />
                <div class="form-group" style="margin-bottom: 1rem;">
                    <textarea asp-for="Reply.Content" rows="4" class="form-control" placeholder="Write your reply here..."></textarea>
                    <span asp-validation-for="Reply.Content" style="color: #dc2626; font-size: 0.875rem;"></span>
                </div>
                <div>
                    <button type="submit" class="btn">Post Reply</button>
                </div>
            </form>
        </div>
    }
    else
    {
        <div class="card" style="background: #f8fafc; text-align: center;">
            <p style="margin: 0;">You must be <a asp-area="Identity" asp-page="/Account/Login">logged in</a> to post a reply.</p>
        </div>
    }
}
