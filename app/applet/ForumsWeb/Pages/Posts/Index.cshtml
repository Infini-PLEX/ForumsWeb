@page
@model ForumsWeb.Pages.Posts.IndexModel
@{
    ViewData["Title"] = Model.Forum?.Title ?? "Posts";
}

<div style="margin-bottom: 1.5rem;">
    <a asp-page="/Index">&larr; Back to Forums</a>
</div>

@if (Model.Forum != null)
{
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <div>
            <h1 style="margin: 0;">@Model.Forum.Title</h1>
            <p style="color: #64748b; margin-top: 0.5rem; margin-bottom: 0;">@Model.Forum.Description</p>
        </div>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a asp-page="/Posts/Create" asp-route-forumId="@Model.ForumId" class="btn">Create New Post</a>
        }
    </div>

    @if (Model.Posts != null && Model.Posts.Any())
    {
        <div style="display: flex; flex-direction: column; gap: 1rem;">
            @foreach (var post in Model.Posts)
            {
                <div class="card" style="padding: 1rem 1.5rem;">
                    <h3 style="margin-top: 0; margin-bottom: 0.5rem;"><a asp-page="/Posts/Details" asp-route-id="@post.Id">@post.Title</a></h3>
                    <small style="color: #64748b;">Posted on @post.CreatedAt.ToString("MMM dd, yyyy - HH:mm")</small>
                </div>
            }
        </div>
    }
    else
    {
        <div class="card">
            <p style="margin: 0; text-align: center; padding: 2rem;">No posts yet. Be the first to start a discussion!</p>
        </div>
    }
}
