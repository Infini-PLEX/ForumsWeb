@page
@model ForumsWeb.Pages.Admin.Forums.CreateModel
@{
    ViewData["Title"] = "Create Forum";
}

<div style="margin-bottom: 1.5rem;">
    <a asp-page="./Index">&larr; Back to Forums List</a>
</div>

<div class="card">
    <h1 style="margin-top: 0;">Create a New Forum Category</h1>
    <hr />
    <form method="post">
        <div class="form-group">
            <label asp-for="Forum.Title">Title</label>
            <input asp-for="Forum.Title" class="form-control" />
            <span asp-validation-for="Forum.Title" style="color: #dc2626; font-size: 0.875rem;"></span>
        </div>
        <div class="form-group">
            <label asp-for="Forum.Description">Description</label>
            <textarea asp-for="Forum.Description" rows="4" class="form-control"></textarea>
            <span asp-validation-for="Forum.Description" style="color: #dc2626; font-size: 0.875rem;"></span>
        </div>
        <div style="margin-top: 1.5rem;">
            <button type="submit" class="btn">Create Forum</button>
        </div>
    </form>
</div>
