@page "{id:int}"
@model ForumsWeb.Pages.Admin.Posts.EditModel
@{
    ViewData["Title"] = "Edit Post";
}

<div style="margin-bottom: 1.5rem;">
    <a asp-page="./Index">&larr; Back to Posts List</a>
</div>

<div class="card">
    <h1 style="margin-top: 0;">Edit Post as Admin</h1>
    <hr />
    <form method="post">
        <input type="hidden" asp-for="Post.Id" />
        <input type="hidden" asp-for="Post.ForumId" />
        <input type="hidden" asp-for="Post.UserId" />
        <input type="hidden" asp-for="Post.CreatedAt" />
        
        <div class="form-group">
            <label asp-for="Post.Title">Title</label>
            <input asp-for="Post.Title" class="form-control" />
            <span asp-validation-for="Post.Title" style="color: #dc2626; font-size: 0.875rem;"></span>
        </div>
        <div class="form-group">
            <label asp-for="Post.Content">Post Content</label>
            <textarea asp-for="Post.Content" rows="6" class="form-control"></textarea>
            <span asp-validation-for="Post.Content" style="color: #dc2626; font-size: 0.875rem;"></span>
        </div>
        <div style="margin-top: 1.5rem;">
            <button type="submit" class="btn" style="background: #eab308;">Save Changes</button>
        </div>
    </form>
</div>
