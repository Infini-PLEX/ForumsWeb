@page
@model ForumsWeb.Pages.Admin.Posts.IndexModel
@{
    ViewData["Title"] = "Manage Posts";
}

<div style="margin-bottom: 1.5rem;">
    <a asp-page="/Admin/Index">&larr; Back to Admin Panel</a>
</div>

<div style="display: flex; justify-content: space-between; align-items: center;">
    <h1 style="margin-top: 0;">Manage Posts</h1>
</div>
<hr />

<table style="width: 100%; border-collapse: collapse; margin-top: 1rem;">
    <thead>
        <tr style="background: #f1f5f9; text-align: left;">
            <th style="padding: 1rem; border: 1px solid var(--border);">Forum</th>
            <th style="padding: 1rem; border: 1px solid var(--border);">Title/Author</th>
            <th style="padding: 1rem; border: 1px solid var(--border);">Created</th>
            <th style="padding: 1rem; border: 1px solid var(--border); width: 220px;">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Posts) {
            <tr>
                <td style="padding: 1rem; border: 1px solid var(--border);">@item.Forum?.Title</td>
                <td style="padding: 1rem; border: 1px solid var(--border);">
                    <strong>@item.Title</strong><br/>
                    <small style="color: #64748b;">@item.User?.Email</small>
                </td>
                <td style="padding: 1rem; border: 1px solid var(--border);">@item.CreatedAt.ToString("MMM dd, yyyy")</td>
                <td style="padding: 1rem; border: 1px solid var(--border);">
                    <div style="display: flex; gap: 0.5rem;">
                        <a asp-page="/Posts/Details" asp-route-id="@item.Id" class="btn" style="background: #64748b;">View</a>
                        <a asp-page="./Edit" asp-route-id="@item.Id" class="btn" style="background: #eab308;">Edit</a>
                        <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id" onsubmit="return confirm('Delete this post and all its replies?');">
                            <button type="submit" class="btn" style="background: #ef4444;">Delete</button>
                        </form>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>
